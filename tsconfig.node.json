{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "strict": true,
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "server/**/*.ts",
    "scripts/**/*.ts",
    "worker/**/*.ts",
    "worker-configuration.d.ts"
  ]
}
